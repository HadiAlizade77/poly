# Database
# For local dev (app running on host, DB in Docker): use localhost
# For production (app in Docker container):          use postgres (service hostname)
DATABASE_URL=postgresql://polymarket:polymarket@localhost:5432/polymarket
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_DB=polymarket

# Redis
# For local dev: redis://localhost:6379
# For production (in Docker): redis://redis:6379
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Polymarket
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# Claude AI
ANTHROPIC_API_KEY=

# JWT
JWT_SECRET=change-me-in-production

# Logging
LOG_LEVEL=debug

# Risk
KILL_SWITCH_ENABLED=false
MAX_DAILY_LOSS=100
MAX_POSITION_SIZE=50
MAX_TOTAL_EXPOSURE=500
